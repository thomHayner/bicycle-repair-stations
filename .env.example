# Overpass API endpoint
# Default: public overpass-api.de instance
# Alternative mirror: https://overpass.kumi.systems/api/interpreter
VITE_OVERPASS_ENDPOINT=https://overpass-api.de/api/interpreter

# Default search radius in km (must be one of: 0.5, 1, 2, 5)
VITE_DEFAULT_RADIUS_KM=2

# Fallback coordinates shown when geolocation is denied
# Default: central London
VITE_FALLBACK_LAT=51.505
VITE_FALLBACK_LNG=-0.09
