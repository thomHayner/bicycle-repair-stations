# Overpass API endpoint
# Default: public overpass-api.de instance
# Alternative mirror: https://overpass.kumi.systems/api/interpreter
VITE_OVERPASS_ENDPOINT=https://overpass-api.de/api/interpreter

# Bug report issue integration (server-side only; do not prefix with VITE_)
# Fine-grained GitHub token with Issues: Read and Write on this repo
GITHUB_ISSUES_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# Optional strict origin check for /api/report-bug
# Comma-separated allow-list (apex,www,dev, etc.)
APP_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://dev.yourdomain.com

# Stripe (server-side only; do not prefix with VITE_)
# Secret key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Analytics debug (optional)
# When set to "true" in dev, trackEvent() forwards to Vercel Analytics
# and logs to the console. Leave unset in dev to keep the production
# dashboard free of local noise; prod always tracks.
VITE_ANALYTICS_DEBUG=

# --- Sentry (added 2026-04-17) ---

# Client DSN (Vite-exposed). When unset, Sentry initialization is a no-op,
# so local dev and forks work without a Sentry account.
VITE_SENTRY_DSN=

# Optional: tag events with a release identifier (e.g. a git SHA).
# On Vercel, wire from VERCEL_GIT_COMMIT_SHA at build time.
VITE_SENTRY_RELEASE=

# Build-time only (do NOT prefix with VITE_ — must stay server-side).
# Required together to enable the @sentry/vite-plugin source-map upload
# during `vite build`. When any is missing, the plugin is skipped and the
# build emits no source maps.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
